{
    "name": "tailwind-pastel",
    "displayName": "Tailwind Pastel",
    "description": "Highlights Tailwind utility classes by category with distinct colors for visual scanning",
    "version": "0.0.2",
    "publisher": "alkemic-studio",
    "license": "MIT",
    "icon": "icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/juncha9/tailwind-pastel.git"
    },
    "bugs": {
        "url": "https://github.com/juncha9/tailwind-pastel/issues"
    },
    "homepage": "https://github.com/juncha9/tailwind-pastel#readme",
    "galleryBanner": {
        "color": "#1e293b",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.109.0"
    },
    "categories": [
        "Programming Languages",
        "Visualization",
        "Other"
    ],
    "keywords": [
        "tailwind",
        "tailwindcss",
        "highlight",
        "category",
        "className"
    ],
    "activationEvents": [
        "onLanguage:typescriptreact",
        "onLanguage:javascriptreact",
        "onLanguage:html",
        "onLanguage:vue",
        "onLanguage:svelte",
        "onLanguage:astro"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": {
            "title": "Tailwind Pastel",
            "properties": {
                "tailwindPastel.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Tailwind class category highlighting"
                }
            }
        },
        "commands": [
            {
                "command": "tailwindPastel.toggle",
                "title": "Toggle Highlighting",
                "category": "Tailwind Pastel"
            }
        ]
    },
    "scripts": {
        "build": "tsup",
        "watch": "tsup --watch",
        "typecheck": "tsc --noEmit -p ./",
        "package": "npx @vscode/vsce package",
        "publish": "npx @vscode/vsce publish"
    },
    "devDependencies": {
        "@resvg/resvg-js": "^2.6.2",
        "@types/node": "^22.19.17",
        "@types/vscode": "^1.109.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    }
}
