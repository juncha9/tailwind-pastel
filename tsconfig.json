{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2022",
        "lib": ["ES2022"],
        "outDir": "./dist",
        "rootDir": "./src",
        "noEmit": true,
        "paths": {
            "@/*": ["./src/*"]
        },
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["node", "vscode"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", ".vscode-test", "dist", "/samples/**/*"]
}
